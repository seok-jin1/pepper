!version-2_integrated/exported_diversity/shannon.tsv
!version-2_integrated/exported_diversity/ordination.txt
!version-2_integrated/integrated_metadata.tsv
!version-2_integrated/exported_table_raw/feature-table.tsv
!version-2_integrated/exported_denoising_stats/stats.tsv
!version-2_integrated/picrust2_out/pathways_out/path_abun_unstrat.tsv.gz
!version-2_integrated/metacyc_pathways_info.txt.gz
