# ==========================================
# ISS Chile Pepper Microbiome - .gitignore
# ==========================================

# Manuscript files
PLPHYS-S-26-00532 (2).pdf
Supplementary Figures.docx
manuscript 20260318.pdf
manuscript 20260318.docx
Supplementary Figures 20260318.pdf
Supplementary Figures 20260318.docx
Supplementary Materials and Methods.docx
Supplementary Materials and Methods 260318.docx

# Raw sequencing data (download via 00_download_data.py)
external_data/
*.fastq.gz
*.fastq

# QIIME2 artifacts (large binary files, generated by 05_qiime2_pipeline.sh)
version-2_integrated/*.qza
version-2_integrated/*.qzv
version-2_integrated/demux.qza

# Exported BIOM files (TSV versions are tracked instead)
*.biom

# PICRUSt2 intermediate files
version-2_integrated/picrust2_out/intermediate/
version-2_integrated/picrust2_out/marker_predicted_and_nsti.tsv.gz

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Conda / Virtual environments (use envs/*.yml to recreate)
.env
.venv
env/
venv/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# OS-generated files
.DS_Store
Thumbs.db
*.swp
*~

# Auto-generated PDF copies of manuscript figures (created by 08 and 09)
manuscript_figures/

# Log files
*.log

# Generated at runtime (machine-specific)
SESSION_INFO.txt

# Zenodo upload archive (not for git)
*.tar.gz

# FAPROTAX installer (download separately)
FAPROTAX_*.zip

# IDE
.vscode/
.idea/

